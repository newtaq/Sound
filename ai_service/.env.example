# =========================
# AI providers
# =========================

AI_PROVIDER_NAMES=groq,groq_search,groq_vision,content_mock,mock
AI_PROVIDER_ENABLE_FALLBACK=true
AI_PROVIDER_STREAM_FALLBACK_TO_GENERATE=true


# =========================
# AI client
# =========================

AI_CLIENT_USE_HISTORY_BY_DEFAULT=false
AI_CLIENT_SAVE_HISTORY_BY_DEFAULT=true
AI_CLIENT_HISTORY_LIMIT=20


# =========================
# Groq
# =========================

GROQ_API_KEYS=PASTE_GROQ_KEY_1,PASTE_GROQ_KEY_2

AI_PROVIDER_GROQ_MODEL=llama-3.3-70b-versatile
AI_PROVIDER_GROQ_SEARCH_MODEL=groq/compound-mini
AI_PROVIDER_GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

AI_PROVIDER_GROQ_TEMPERATURE=0.2
AI_PROVIDER_GROQ_MAX_COMPLETION_TOKENS=4096
AI_PROVIDER_GROQ_TIMEOUT_SECONDS=60
AI_PROVIDER_GROQ_MAX_RETRIES=1
AI_PROVIDER_GROQ_RETRY_DELAY_SECONDS=1
AI_PROVIDER_GROQ_KEY_STRATEGY=round_robin


# =========================
# Mira Telegram provider
# =========================

AI_PROVIDER_MIRA_TELEGRAM_API_ID=PASTE_TELEGRAM_API_ID
AI_PROVIDER_MIRA_TELEGRAM_API_HASH=PASTE_TELEGRAM_API_HASH
AI_PROVIDER_MIRA_TELEGRAM_SESSION_NAME=mira_telegram
AI_PROVIDER_MIRA_TELEGRAM_SESSION_STRING=

AI_PROVIDER_MIRA_TELEGRAM_BOT_USERNAME=mira
AI_PROVIDER_MIRA_TELEGRAM_BOT_TOKEN=PASTE_MIRA_BOT_TOKEN

AI_PROVIDER_MIRA_TELEGRAM_CHAT_ID=PASTE_CHAT_ID
AI_PROVIDER_MIRA_TELEGRAM_STREAM_CHAT_ID=mira

AI_PROVIDER_MIRA_TELEGRAM_FORUM_TOPICS_ENABLED=true
AI_PROVIDER_MIRA_TELEGRAM_TOPIC_STORE_PATH=.runtime/mira_topics.json
AI_PROVIDER_MIRA_TELEGRAM_TOPIC_NAME_PREFIX=AI session

AI_PROVIDER_MIRA_TELEGRAM_TRIGGER_PREFIX=мира

AI_PROVIDER_MIRA_TELEGRAM_TIMEOUT_SECONDS=120
AI_PROVIDER_MIRA_TELEGRAM_IDLE_TIMEOUT_SECONDS=3

AI_PROVIDER_MIRA_TELEGRAM_MAX_TEXT_MESSAGE_LENGTH=4096
AI_PROVIDER_MIRA_TELEGRAM_MAX_CAPTION_LENGTH=1024
AI_PROVIDER_MIRA_TELEGRAM_MAX_MEDIA_COUNT=10

AI_PROVIDER_MIRA_TELEGRAM_MAX_RETRIES=1
AI_PROVIDER_MIRA_TELEGRAM_RETRY_DELAY_SECONDS=1

AI_PROVIDER_MIRA_TELEGRAM_ONE_ACTIVE_REQUEST_PER_SESSION=true
AI_PROVIDER_MIRA_TELEGRAM_SEND_LARGE_TEXT_AS_FILE=true
AI_PROVIDER_MIRA_TELEGRAM_ALLOW_MEDIA_GROUP=true

AI_PROVIDER_MIRA_TELEGRAM_PROXY_SCHEME=socks5
AI_PROVIDER_MIRA_TELEGRAM_PROXY_HOSTNAME=127.0.0.1
AI_PROVIDER_MIRA_TELEGRAM_PROXY_PORT=10808
AI_PROVIDER_MIRA_TELEGRAM_PROXY_USERNAME=
AI_PROVIDER_MIRA_TELEGRAM_PROXY_PASSWORD=


# =========================
# Telegram visual debug
# =========================

AI_TELEGRAM_DEBUG_ENABLED=false
AI_TELEGRAM_DEBUG_BOT_TOKEN=PASTE_DEBUG_BOT_TOKEN
AI_TELEGRAM_DEBUG_CHAT_ID=PASTE_DEBUG_CHAT_ID

AI_TELEGRAM_DEBUG_CREATE_TOPICS_ENABLED=true
AI_TELEGRAM_DEBUG_TOPIC_STORE_PATH=.runtime/telegram_debug_topics.json
AI_TELEGRAM_DEBUG_TOPIC_NAME_PREFIX=AI debug

AI_TELEGRAM_DEBUG_MAX_TOPIC_NAME_LENGTH=128
AI_TELEGRAM_DEBUG_MAX_MESSAGE_LENGTH=3500
AI_TELEGRAM_DEBUG_SEND_TIMEOUT_SECONDS=5

AI_TELEGRAM_DEBUG_INCLUDE_REQUEST_TEXT=true
AI_TELEGRAM_DEBUG_INCLUDE_RESPONSE_TEXT=true
AI_TELEGRAM_DEBUG_INCLUDE_METADATA=true
AI_TELEGRAM_DEBUG_INCLUDE_STREAM_DELTAS=false
AI_TELEGRAM_DEBUG_FAIL_SILENTLY=true
